@using ZaffreMeld.Web.Models.Inventory
@model ItemMstr
@{ ViewData["Title"] = "New Item"; }
<div class="page-header">
    <a asp-action="Items" class="btn btn-sm btn-outline-secondary me-2"><i class="bi bi-arrow-left"></i></a>
    <h4 class="d-inline"><i class="bi bi-plus-circle me-2 text-primary"></i>New Item</h4>
</div>
<form method="post" asp-action="NewItem">
<div class="row g-3">
    <div class="col-md-6"><div class="form-section">
        <div class="form-section-title">Item Identity</div>
        <div class="row g-2">
            <div class="col-5"><label class="form-label small">Item # *</label><input name="ItItem" class="form-control form-control-sm" required/></div>
            <div class="col-7"><label class="form-label small">Description *</label><input name="ItDesc" class="form-control form-control-sm" required/></div>
            <div class="col-4"><label class="form-label small">Type</label>
                <select name="ItType" class="form-select form-select-sm">
                    <option value="M">Manufactured</option>
                    <option value="P">Purchased</option>
                    <option value="S">Service</option>
                </select></div>
            <div class="col-4"><label class="form-label small">UOM</label><input name="ItUom" class="form-control form-control-sm" value="EA"/></div>
            <div class="col-4"><label class="form-label small">ABC Class</label>
                <select name="ItAbc" class="form-select form-select-sm">
                    <option value="A">A</option><option value="B">B</option><option value="C" selected>C</option>
                </select></div>
        </div>
    </div></div>
    <div class="col-md-6"><div class="form-section">
        <div class="form-section-title">Planning</div>
        <div class="row g-2">
            <div class="col-4"><label class="form-label small">Lot Size</label><input name="ItLotsize" type="number" class="form-control form-control-sm" value="1"/></div>
            <div class="col-4"><label class="form-label small">Lead Time (days)</label><input name="ItLeadtime" type="number" step="0.1" class="form-control form-control-sm" value="0"/></div>
            <div class="col-4"><label class="form-label small">Safety Stock</label><input name="ItSafetystock" type="number" step="0.01" class="form-control form-control-sm" value="0"/></div>
            <div class="col-6"><label class="form-label small">Default Warehouse</label><input name="ItWh" class="form-control form-control-sm"/></div>
            <div class="col-6"><label class="form-label small">Default Location</label><input name="ItLoc" class="form-control form-control-sm"/></div>
            <div class="col-6"><label class="form-label small">Drawing</label><input name="ItDrawing" class="form-control form-control-sm"/></div>
            <div class="col-6"><label class="form-label small">Revision</label><input name="ItRevision" class="form-control form-control-sm"/></div>
        </div>
    </div></div>
</div>
<div class="d-flex gap-2 mt-3">
    <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Create Item</button>
    <a asp-action="Items" class="btn btn-outline-secondary">Cancel</a>
</div>
</form>
