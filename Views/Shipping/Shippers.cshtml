@using ZaffreMeld.Web.Models.Shipping
@{ ViewData["Title"] = "Shippers"; }
<div class="page-header d-flex justify-content-between align-items-center">
    <h4><i class="bi bi-truck me-2 text-primary"></i>Shippers</h4>
    <a asp-action="NewShipper" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg me-1"></i>New Shipper</a>
</div>
<div class="card mb-3"><div class="card-body py-2">
<form method="get" class="row g-2 align-items-end">
    <div class="col-sm-4"><input name="q" value="@ViewBag.Q" class="form-control form-control-sm" placeholder="Search shipper # or customer..."/></div>
    <div class="col-sm-3"><select name="status" class="form-select form-select-sm">
        <option value="">All</option>
        <option value="O" selected="@(ViewBag.Status=="O")">Open</option>
        <option value="C" selected="@(ViewBag.Status=="C")">Closed</option>
    </select></div>
    <div class="col-auto">
        <button class="btn btn-sm btn-outline-primary" type="submit"><i class="bi bi-search"></i> Search</button>
        <a asp-action="Shippers" class="btn btn-sm btn-outline-secondary ms-1">Clear</a>
    </div>
</form>
</div></div>
<div class="browse-table-wrapper"><table class="table table-sm table-hover mb-0">
    <thead><tr><th>Shipper #</th><th>Customer</th><th>SO #</th><th>Entry Date</th><th>Ship Date</th><th>Carrier</th><th>Track #</th><th class="num">Weight</th><th>Status</th><th></th></tr></thead>
    <tbody>
    @foreach (ShipMstr s in (ViewBag.Shippers as IEnumerable<ShipMstr> ?? Array.Empty<ShipMstr>()))
    {
        <tr>
            <td><a asp-action="Shipper" asp-route-id="@s.ShId" class="fw-semibold">@s.ShId</a></td>
            <td>@s.ShCust</td>
            <td><a asp-controller="Orders" asp-action="SalesOrder" asp-route-id="@s.ShSo">@s.ShSo</a></td>
            <td>@s.ShEntdate</td><td>@s.ShShipdate</td>
            <td>@s.ShCarrier</td><td>@s.ShTrackno</td>
            <td class="num">@s.ShWeight.ToString("N2")</td>
            <td><span class="badge @(s.ShStatus=="O"?"badge-open":"badge-closed")">@(s.ShStatus=="O"?"Open":"Shipped")</span></td>
            <td><a asp-action="Shipper" asp-route-id="@s.ShId" class="btn btn-xs btn-outline-secondary">View</a></td>
        </tr>
    }
    @if (!(ViewBag.Shippers as IEnumerable<ShipMstr> ?? Array.Empty<ShipMstr>()).Any())
    { <tr><td colspan="10" class="text-center text-muted py-4">No shippers found</td></tr> }
    </tbody>
</table></div>
