@using ZaffreMeld.Web.Models.Finance
@{ ViewData["Title"] = "Accounts Receivable"; }
<div class="page-header"><h4><i class="bi bi-receipt me-2 text-primary"></i>Accounts Receivable</h4></div>
<div class="card mb-3"><div class="card-body py-2">
<form method="get" class="row g-2 align-items-end">
    <div class="col-sm-4"><input name="q" value="@ViewBag.Q" class="form-control form-control-sm" placeholder="Search invoice # or customer..."/></div>
    <div class="col-sm-3"><select name="status" class="form-select form-select-sm">
        <option value="">All</option><option value="O" selected="@(ViewBag.Status=="O")">Open</option>
        <option value="C" selected="@(ViewBag.Status=="C")">Closed</option>
        <option value="V" selected="@(ViewBag.Status=="V")">Void</option>
    </select></div>
    <div class="col-auto">
        <button class="btn btn-sm btn-outline-primary" type="submit"><i class="bi bi-search"></i> Search</button>
        <a asp-action="AR" class="btn btn-sm btn-outline-secondary ms-1">Clear</a>
    </div>
</form>
</div></div>
<div class="browse-table-wrapper"><table class="table table-sm table-hover mb-0">
    <thead><tr><th>Invoice #</th><th>Customer</th><th>Entry Date</th><th>Due Date</th><th class="num">Amount</th><th>Currency</th><th>Status</th><th></th></tr></thead>
    <tbody>
    @foreach (ArMstr ar in (ViewBag.Invoices as IEnumerable<ArMstr> ?? Array.Empty<ArMstr>()))
    {
        <tr>
            <td><a asp-action="ARInvoice" asp-route-id="@ar.ArId" class="fw-semibold">@ar.ArId</a></td>
            <td>@ar.ArCust</td><td>@ar.ArEntdate</td><td>@ar.ArDuedate</td>
            <td class="num">@ar.ArAmt.ToString("N2")</td>
            <td>@ar.ArCurr</td>
            <td><span class="badge @(ar.ArStatus=="O"?"badge-open":"badge-closed")">@(ar.ArStatus=="O"?"Open":"Closed")</span></td>
            <td><a asp-action="ARInvoice" asp-route-id="@ar.ArId" class="btn btn-xs btn-outline-secondary">View</a></td>
        </tr>
    }
    @if (!(ViewBag.Invoices as IEnumerable<ArMstr> ?? Array.Empty<ArMstr>()).Any())
    { <tr><td colspan="8" class="text-center text-muted py-4">No invoices found</td></tr> }
    </tbody>
</table></div>
