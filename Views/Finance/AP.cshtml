@using ZaffreMeld.Web.Models.Finance
@{ ViewData["Title"] = "Accounts Payable"; }
<div class="page-header"><h4><i class="bi bi-credit-card me-2 text-primary"></i>Accounts Payable</h4></div>
<div class="card mb-3"><div class="card-body py-2">
<form method="get" class="row g-2 align-items-end">
    <div class="col-sm-4"><input name="q" value="@ViewBag.Q" class="form-control form-control-sm" placeholder="Search voucher # or vendor..."/></div>
    <div class="col-sm-3"><select name="status" class="form-select form-select-sm">
        <option value="">All</option><option value="O" selected="@(ViewBag.Status=="O")">Open</option>
        <option value="C" selected="@(ViewBag.Status=="C")">Closed</option>
    </select></div>
    <div class="col-auto">
        <button class="btn btn-sm btn-outline-primary" type="submit"><i class="bi bi-search"></i> Search</button>
        <a asp-action="AP" class="btn btn-sm btn-outline-secondary ms-1">Clear</a>
    </div>
</form>
</div></div>
<div class="browse-table-wrapper"><table class="table table-sm table-hover mb-0">
    <thead><tr><th>Voucher #</th><th>Vendor</th><th>Entry Date</th><th>Due Date</th><th>Description</th><th class="num">Amount</th><th>Status</th><th></th></tr></thead>
    <tbody>
    @foreach (ApMstr ap in (ViewBag.Vouchers as IEnumerable<ApMstr> ?? Array.Empty<ApMstr>()))
    {
        <tr>
            <td><a asp-action="APVoucher" asp-route-id="@ap.ApId" class="fw-semibold">@ap.ApId</a></td>
            <td>@ap.ApVend</td><td>@ap.ApEntdate</td><td>@ap.ApDuedate</td>
            <td>@ap.ApDesc</td>
            <td class="num">@ap.ApAmt.ToString("N2")</td>
            <td><span class="badge @(ap.ApStatus=="O"?"badge-open":"badge-closed")">@(ap.ApStatus=="O"?"Open":"Closed")</span></td>
            <td><a asp-action="APVoucher" asp-route-id="@ap.ApId" class="btn btn-xs btn-outline-secondary">View</a></td>
        </tr>
    }
    @if (!(ViewBag.Vouchers as IEnumerable<ApMstr> ?? Array.Empty<ApMstr>()).Any())
    { <tr><td colspan="8" class="text-center text-muted py-4">No vouchers found</td></tr> }
    </tbody>
</table></div>
