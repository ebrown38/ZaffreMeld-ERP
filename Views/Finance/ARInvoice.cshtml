@using ZaffreMeld.Web.Models.Finance
@using ZaffreMeld.Web.Models.Orders
@model ArMstr
@{ ViewData["Title"] = $"Invoice {Model.ArId}"; }
<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <a asp-action="AR" class="btn btn-sm btn-outline-secondary me-2"><i class="bi bi-arrow-left"></i></a>
        <h4 class="d-inline"><i class="bi bi-receipt me-2 text-primary"></i>Invoice @Model.ArId</h4>
        <span class="badge ms-2 @(Model.ArStatus=="O"?"badge-open":"badge-closed")">@(Model.ArStatus=="O"?"Open":"Closed")</span>
    </div>
</div>
<div class="row g-3 mb-3">
    <div class="col-md-6"><div class="form-section">
        <div class="form-section-title">Invoice Details</div>
        <div class="row g-2">
            <div class="col-6"><span class="detail-label">Invoice #</span><div class="detail-value">@Model.ArId</div></div>
            <div class="col-6"><span class="detail-label">Reference</span><div>@Model.ArRef</div></div>
            <div class="col-6"><span class="detail-label">Entry Date</span><div>@Model.ArEntdate</div></div>
            <div class="col-6"><span class="detail-label">Due Date</span><div>@Model.ArDuedate</div></div>
            <div class="col-6"><span class="detail-label">Amount</span><div class="fw-bold text-primary">@Model.ArAmt.ToString("N2") @Model.ArCurr</div></div>
            <div class="col-6"><span class="detail-label">Posted</span><div>@(Model.ArPosted?"Yes":"No")</div></div>
        </div>
    </div></div>
    <div class="col-md-6"><div class="form-section">
        <div class="form-section-title">Customer</div>
        @if (ViewBag.Customer is CmMstr c)
        {
            <div class="fw-semibold">@c.CmName</div>
            <div class="text-muted small">@c.CmCode</div>
            <div>@c.CmLine1</div>
            <div>@c.CmCity, @c.CmState @c.CmZip</div>
        }
        <a asp-controller="Orders" asp-action="Customer" asp-route-id="@Model.ArCust" class="btn btn-xs btn-outline-secondary mt-2">View Customer</a>
    </div></div>
</div>
<div class="browse-table-wrapper">
    <div class="px-3 py-2 bg-light border-bottom"><span class="fw-semibold small text-muted">INVOICE LINES</span></div>
    <table class="table table-sm table-hover mb-0">
        <thead><tr><th>Line</th><th>Item</th><th>Reference</th><th class="num">Amount</th></tr></thead>
        <tbody>
        @foreach (ArdMstr line in (ViewBag.Lines as IEnumerable<ArdMstr> ?? Array.Empty<ArdMstr>()))
        {
            <tr>
                <td>@line.ArdLine</td>
                <td>@line.ArdItem</td>
                <td>@line.ArdRef</td>
                <td class="num">@line.ArdAmt.ToString("N2")</td>
            </tr>
        }
        </tbody>
    </table>
</div>
