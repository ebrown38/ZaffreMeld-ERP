@using ZaffreMeld.Web.Models.Finance
@{ ViewData["Title"] = "Balance Sheet"; var balances = ViewBag.Balances as Dictionary<string,decimal> ?? new(); var accounts = ViewBag.Accounts as List<AcctMstr> ?? new(); }
<div class="page-header d-flex justify-content-between align-items-center">
    <h4><i class="bi bi-bar-chart me-2 text-primary"></i>Balance Sheet</h4>
    <div class="text-muted small">As of Period @ViewBag.Period / @ViewBag.Year</div>
</div>
<div class="card mb-3"><div class="card-body py-2">
<form method="get" class="row g-2 align-items-end">
    <div class="col-auto"><label class="form-label small mb-1">Year</label><input name="year" value="@ViewBag.Year" class="form-control form-control-sm" style="width:80px"/></div>
    <div class="col-auto"><label class="form-label small mb-1">Period</label>
        <select name="period" class="form-select form-select-sm" style="width:80px">
            @for (int p = 1; p <= 12; p++)
            { <option value="@p.ToString("D2")" selected="@(ViewBag.Period==p.ToString("D2"))">@p.ToString("D2")</option> }
        </select></div>
    <div class="col-auto"><button class="btn btn-sm btn-outline-primary" type="submit"><i class="bi bi-arrow-repeat"></i> Refresh</button></div>
</form>
</div></div>
@{ 
    decimal totalAssets = accounts.Where(a=>a.Type=="A").Sum(a=>balances.GetValueOrDefault(a.Id,0));
    decimal totalLiab   = accounts.Where(a=>a.Type=="L").Sum(a=>balances.GetValueOrDefault(a.Id,0));
    decimal totalEquity = accounts.Where(a=>a.Type=="E").Sum(a=>balances.GetValueOrDefault(a.Id,0));
}
<div class="row g-3">
    <div class="col-md-6">
        <div class="form-section mb-3">
            <div class="form-section-title">ASSETS</div>
            <table class="table table-sm mb-0">
                <tbody>
                @foreach (AcctMstr a in accounts.Where(a=>a.Type=="A"))
                {
                    <tr><td><a asp-action="Account" asp-route-id="@a.Id">@a.Id</a> — @a.Desc</td><td class="num">@balances.GetValueOrDefault(a.Id,0).ToString("N2")</td></tr>
                }
                </tbody>
                <tfoot class="fw-bold table-light"><tr><td>Total Assets</td><td class="num">@totalAssets.ToString("N2")</td></tr></tfoot>
            </table>
        </div>
    </div>
    <div class="col-md-6">
        <div class="form-section mb-3">
            <div class="form-section-title">LIABILITIES</div>
            <table class="table table-sm mb-0">
                <tbody>
                @foreach (AcctMstr a in accounts.Where(a=>a.Type=="L"))
                {
                    <tr><td><a asp-action="Account" asp-route-id="@a.Id">@a.Id</a> — @a.Desc</td><td class="num">@balances.GetValueOrDefault(a.Id,0).ToString("N2")</td></tr>
                }
                </tbody>
                <tfoot class="fw-bold table-light"><tr><td>Total Liabilities</td><td class="num">@totalLiab.ToString("N2")</td></tr></tfoot>
            </table>
        </div>
        <div class="form-section">
            <div class="form-section-title">EQUITY</div>
            <table class="table table-sm mb-0">
                <tbody>
                @foreach (AcctMstr a in accounts.Where(a=>a.Type=="E"))
                {
                    <tr><td><a asp-action="Account" asp-route-id="@a.Id">@a.Id</a> — @a.Desc</td><td class="num">@balances.GetValueOrDefault(a.Id,0).ToString("N2")</td></tr>
                }
                </tbody>
                <tfoot class="fw-bold table-light"><tr><td>Total Equity</td><td class="num">@totalEquity.ToString("N2")</td></tr></tfoot>
            </table>
        </div>
    </div>
</div>
<div class="form-section mt-3 d-flex justify-content-between align-items-center">
    <span class="fw-bold">Assets = Liabilities + Equity</span>
    <span class="@(Math.Abs(totalAssets-(totalLiab+totalEquity))<0.01m?"text-success fw-bold":"text-danger fw-bold")">
        @totalAssets.ToString("N2") = @((totalLiab+totalEquity).ToString("N2"))
        @(Math.Abs(totalAssets-(totalLiab+totalEquity))<0.01m?" ✓":" (OUT OF BALANCE)")
    </span>
</div>
