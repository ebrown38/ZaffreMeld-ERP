@using ZaffreMeld.Web.Models.Finance
@{ ViewData["Title"] = "GL Transactions"; }
<div class="page-header"><h4><i class="bi bi-table me-2 text-primary"></i>GL Transactions</h4></div>
<div class="card mb-3"><div class="card-body py-2">
<form method="get" class="row g-2 align-items-end">
    <div class="col-sm-3">
        <label class="form-label small mb-1">Account</label>
        <select name="acct" class="form-select form-select-sm">
            <option value="">All Accounts</option>
            @foreach (AcctMstr a in (ViewBag.Accounts as IEnumerable<AcctMstr> ?? Array.Empty<AcctMstr>()))
            { <option value="@a.Id" selected="@(ViewBag.Acct==(string)a.Id)">@a.Id — @a.Desc</option> }
        </select>
    </div>
    <div class="col-sm-2"><label class="form-label small mb-1">From</label><input name="from" type="date" value="@ViewBag.From" class="form-control form-control-sm"/></div>
    <div class="col-sm-2"><label class="form-label small mb-1">To</label><input name="to" type="date" value="@ViewBag.To" class="form-control form-control-sm"/></div>
    <div class="col-sm-2"><label class="form-label small mb-1">Type</label>
        <select name="source" class="form-select form-select-sm">
            <option value="">All Types</option>
            <option value="JL">Journal</option><option value="AP">AP</option><option value="AR">AR</option>
            <option value="IN">Invoice</option><option value="SH">Shipping</option><option value="RC">Receiving</option>
        </select>
    </div>
    <div class="col-auto"><button class="btn btn-sm btn-outline-primary" type="submit"><i class="bi bi-filter"></i> Filter</button></div>
</form>
</div></div>
<div class="browse-table-wrapper"><table class="table table-sm table-hover mb-0">
    <thead><tr><th>Date</th><th>Account</th><th>Reference</th><th>Description</th><th>Type</th><th>Doc</th><th class="num">Amount</th><th>Period</th><th>Posted</th></tr></thead>
    <tbody>
    @foreach (GlTran t in (ViewBag.Transactions as IEnumerable<GlTran> ?? Array.Empty<GlTran>()))
    {
        <tr>
            <td>@t.GltEffdate</td>
            <td><a asp-action="Account" asp-route-id="@t.GltAcct">@t.GltAcct</a></td>
            <td>@t.GltRef</td>
            <td>@t.GltDesc</td>
            <td><span class="badge bg-light text-dark border small">@t.GltType</span></td>
            <td>@t.GltDoc</td>
            <td class="num @(t.GltAmt>=0?"text-success":"text-danger")">@t.GltAmt.ToString("N2")</td>
            <td>@t.GltYear/@t.GltPeriod</td>
            <td>@(t.GltPosted ? "✓" : "")</td>
        </tr>
    }
    @if (!(ViewBag.Transactions as IEnumerable<GlTran> ?? Array.Empty<GlTran>()).Any())
    { <tr><td colspan="9" class="text-center text-muted py-4">No transactions found</td></tr> }
    </tbody>
</table></div>
