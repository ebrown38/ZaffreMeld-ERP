@using ZaffreMeld.Web.Models.Purchasing
@{ ViewData["Title"] = "New Receiver"; }
<div class="page-header">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary me-2"><i class="bi bi-arrow-left"></i></a>
    <h4 class="d-inline"><i class="bi bi-plus-circle me-2 text-primary"></i>New Receiver</h4>
</div>
<div class="card">
    <div class="card-body">
        <p class="text-muted">Select an open Purchase Order to receive against.</p>
        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label small">Purchase Order *</label>
                <select class="form-select form-select-sm">
                    <option value="">-- Select Open PO --</option>
                    @foreach (PoMstr po in (ViewBag.OpenPos as IEnumerable<PoMstr> ?? Array.Empty<PoMstr>()))
                    { <option value="@po.PoNbr">@po.PoNbr — @po.PoVend (@po.PoReqdate)</option> }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label small">Receive Date</label>
                <input type="date" class="form-control form-control-sm" value="@DateTime.Today.ToString("yyyy-MM-dd")"/>
            </div>
            <div class="col-md-3">
                <label class="form-label small">Ship Via</label>
                <input type="text" class="form-control form-control-sm"/>
            </div>
            <div class="col-md-3">
                <label class="form-label small">Tracking #</label>
                <input type="text" class="form-control form-control-sm"/>
            </div>
        </div>
        <div class="alert alert-info mt-3 small">
            <i class="bi bi-info-circle me-1"></i>
            Full receiver creation is available via <code>POST /api/receiving</code>. Select a PO above to pre-populate lines.
        </div>
    </div>
</div>
