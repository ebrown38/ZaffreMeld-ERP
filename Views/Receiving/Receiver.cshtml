@model RecvMstr
@{ ViewData["Title"] = $"Receiver {Model.RvId}"; }
<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <a asp-action="Index" class="btn btn-sm btn-outline-secondary me-2"><i class="bi bi-arrow-left"></i></a>
        <h4 class="d-inline"><i class="bi bi-box-arrow-in-down me-2 text-primary"></i>Receiver @Model.RvId</h4>
        <span class="badge ms-2 @(Model.RvStatus=="O"?"badge-open":"badge-closed")">@(Model.RvStatus=="O"?"Open":"Closed")</span>
    </div>
</div>
<div class="row g-3 mb-3">
    <div class="col-md-6"><div class="form-section">
        <div class="form-section-title">Receiver Details</div>
        <div class="row g-2">
            <div class="col-6"><span class="detail-label">Receiver #</span><div class="detail-value">@Model.RvId</div></div>
            <div class="col-6"><span class="detail-label">Recv Date</span><div>@Model.RvRecvdate</div></div>
            <div class="col-6"><span class="detail-label">Site</span><div>@Model.RvSite</div></div>
            <div class="col-6"><span class="detail-label">Ship Via</span><div>@Model.RvShipvia</div></div>
            <div class="col-6"><span class="detail-label">Track #</span><div>@Model.RvTrackno</div></div>
            <div class="col-6"><span class="detail-label">Weight</span><div>@Model.RvWeight.ToString("N2")</div></div>
            <div class="col-6"><span class="detail-label">Posted</span><div>@(Model.RvPosted?"Yes":"No")</div></div>
            @if (!string.IsNullOrEmpty(Model.RvNote))
            { <div class="col-12"><span class="detail-label">Notes</span><div class="small">@Model.RvNote</div></div> }
        </div>
    </div></div>
    <div class="col-md-6"><div class="form-section">
        <div class="form-section-title">Vendor</div>
        @if (ViewBag.Vendor is VdMstr v)
        {
            <div class="fw-semibold">@v.VdName</div>
            <div class="text-muted small">@v.VdAddr</div>
            <div>@v.VdLine1</div>
            <div>@v.VdCity, @v.VdState @v.VdZip</div>
        }
        <a asp-controller="Purchasing" asp-action="Vendor" asp-route-id="@Model.RvVend" class="btn btn-xs btn-outline-secondary mt-2">View Vendor</a>
    </div></div>
</div>
<div class="browse-table-wrapper">
    <div class="px-3 py-2 bg-light border-bottom"><span class="fw-semibold small text-muted">RECEIVED LINES</span></div>
    <table class="table table-sm table-hover mb-0">
        <thead><tr><th>PO #</th><th>PO Line</th><th>Item</th><th class="num">Qty</th><th class="num">Price</th><th>UOM</th><th>Lot</th><th>WH</th><th>Loc</th><th>Status</th></tr></thead>
        <tbody>
        @foreach (RecvDet line in (ViewBag.Lines as IEnumerable<RecvDet> ?? Array.Empty<RecvDet>()))
        {
            <tr>
                <td><a asp-controller="Purchasing" asp-action="PurchaseOrder" asp-route-id="@line.RvdPo">@line.RvdPo</a></td>
                <td>@line.RvdPoline</td>
                <td><a asp-controller="Inventory" asp-action="Item" asp-route-id="@line.RvdItem">@line.RvdItem</a></td>
                <td class="num">@line.RvdQty.ToString("N2")</td>
                <td class="num">@line.RvdPrice.ToString("N4")</td>
                <td>@line.RvdUom</td>
                <td>@line.RvdLot</td>
                <td>@line.RvdWh</td><td>@line.RvdLoc</td>
                <td><span class="badge @(line.RvdStatus=="O"?"badge-open":"badge-closed")">@line.RvdStatus</span></td>
            </tr>
        }
        </tbody>
    </table>
</div>
