@using ZaffreMeld.Web.Models.Receiving
@{ ViewData["Title"] = "Receiving"; }
<div class="page-header d-flex justify-content-between align-items-center">
    <h4><i class="bi bi-box-arrow-in-down me-2 text-primary"></i>Receivers</h4>
    <a asp-action="NewReceiver" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg me-1"></i>New Receiver</a>
</div>
<div class="card mb-3"><div class="card-body py-2">
<form method="get" class="row g-2 align-items-end">
    <div class="col-sm-4"><input name="q" value="@ViewBag.Q" class="form-control form-control-sm" placeholder="Search receiver # or vendor..."/></div>
    <div class="col-sm-3"><select name="status" class="form-select form-select-sm">
        <option value="">All</option>
        <option value="O" selected="@(ViewBag.Status=="O")">Open</option>
        <option value="C" selected="@(ViewBag.Status=="C")">Closed</option>
    </select></div>
    <div class="col-auto">
        <button class="btn btn-sm btn-outline-primary" type="submit"><i class="bi bi-search"></i> Search</button>
        <a asp-action="Index" class="btn btn-sm btn-outline-secondary ms-1">Clear</a>
    </div>
</form>
</div></div>
<div class="browse-table-wrapper"><table class="table table-sm table-hover mb-0">
    <thead><tr><th>Receiver #</th><th>Vendor</th><th>Recv Date</th><th>Ship Via</th><th>Track #</th><th class="num">Weight</th><th>Status</th><th>Posted</th><th></th></tr></thead>
    <tbody>
    @foreach (RecvMstr r in (ViewBag.Receivers as IEnumerable<RecvMstr> ?? Array.Empty<RecvMstr>()))
    {
        <tr>
            <td><a asp-action="Receiver" asp-route-id="@r.RvId" class="fw-semibold">@r.RvId</a></td>
            <td>@r.RvVend</td><td>@r.RvRecvdate</td>
            <td>@r.RvShipvia</td><td>@r.RvTrackno</td>
            <td class="num">@r.RvWeight.ToString("N2")</td>
            <td><span class="badge @(r.RvStatus=="O"?"badge-open":"badge-closed")">@(r.RvStatus=="O"?"Open":"Closed")</span></td>
            <td>@(r.RvPosted?"✓":"")</td>
            <td><a asp-action="Receiver" asp-route-id="@r.RvId" class="btn btn-xs btn-outline-secondary">View</a></td>
        </tr>
    }
    @if (!(ViewBag.Receivers as IEnumerable<RecvMstr> ?? Array.Empty<RecvMstr>()).Any())
    { <tr><td colspan="9" class="text-center text-muted py-4">No receivers found</td></tr> }
    </tbody>
</table></div>
