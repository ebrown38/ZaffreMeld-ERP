@{ ViewData["Title"] = "Vendors"; }
<div class="page-header d-flex justify-content-between align-items-center">
    <h4><i class="bi bi-building me-2 text-primary"></i>Vendors</h4>
    <a asp-controller="Purchasing" asp-action="NewVendor" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg me-1"></i>New Vendor</a>
</div>
<div class="card mb-3"><div class="card-body py-2">
<form method="get" asp-action="Vendors" class="row g-2 align-items-end">
    <div class="col-sm-4"><input name="q" value="@ViewBag.Q" class="form-control form-control-sm" placeholder="Search code or name..."/></div>
    <div class="col-sm-3"><select name="status" class="form-select form-select-sm">
        <option value="">All</option><option value="A">Active</option><option value="I">Inactive</option>
    </select></div>
    <div class="col-auto">
        <button class="btn btn-sm btn-outline-primary" type="submit"><i class="bi bi-search"></i> Search</button>
        <a asp-action="Vendors" class="btn btn-sm btn-outline-secondary ms-1">Clear</a>
    </div>
</form>
</div></div>
<div class="browse-table-wrapper"><table class="table table-sm table-hover mb-0">
    <thead><tr><th>Code</th><th>Name</th><th>City</th><th>State</th><th>Phone</th><th>Terms</th><th>Currency</th><th>Status</th><th></th></tr></thead>
    <tbody>
    @foreach (VdMstr v in (ViewBag.Vendors as IEnumerable<VdMstr> ?? Array.Empty<VdMstr>()))
    {
        <tr>
            <td><a asp-action="Vendor" asp-route-id="@v.VdAddr" class="fw-semibold">@v.VdAddr</a></td>
            <td>@v.VdName</td><td>@v.VdCity</td><td>@v.VdState</td><td>@v.VdPhone</td>
            <td>@v.VdTerms</td><td>@v.VdCurrency</td>
            <td><span class="badge @(v.VdStatus=="A"?"badge-active":"badge-inactive")">@(v.VdStatus=="A"?"Active":"Inactive")</span></td>
            <td><a asp-action="Vendor" asp-route-id="@v.VdAddr" class="btn btn-xs btn-outline-secondary">View</a></td>
        </tr>
    }
    @if (!(ViewBag.Vendors as IEnumerable<VdMstr> ?? Array.Empty<VdMstr>()).Any())
    { <tr><td colspan="9" class="text-center text-muted py-4">No vendors found</td></tr> }
    </tbody>
</table></div>
