@using ZaffreMeld.Web.Models.HR
@model EmpMstr
@{ ViewData["Title"] = "New Employee"; }
<div class="page-header">
    <a asp-action="Employees" class="btn btn-sm btn-outline-secondary me-2"><i class="bi bi-arrow-left"></i></a>
    <h4 class="d-inline"><i class="bi bi-person-plus me-2 text-primary"></i>New Employee</h4>
</div>
<form method="post" asp-action="NewEmployee">
<div class="row g-3">
    <div class="col-md-6"><div class="form-section">
        <div class="form-section-title">Personal Information</div>
        <div class="row g-2">
            <div class="col-4"><label class="form-label small">Emp # *</label><input name="EmpNbr" class="form-control form-control-sm" required/></div>
            <div class="col-4"><label class="form-label small">First Name</label><input name="EmpFname" class="form-control form-control-sm"/></div>
            <div class="col-4"><label class="form-label small">Last Name *</label><input name="EmpLname" class="form-control form-control-sm" required/></div>
            <div class="col-4"><label class="form-label small">Middle</label><input name="EmpMiddle" class="form-control form-control-sm"/></div>
        </div>
    </div></div>
    <div class="col-md-6"><div class="form-section">
        <div class="form-section-title">Employment Details</div>
        <div class="row g-2">
            <div class="col-4"><label class="form-label small">Type</label>
                <select name="EmpType" class="form-select form-select-sm">
                    <option value="H">Hourly</option><option value="S">Salary</option>
                </select></div>
            <div class="col-4"><label class="form-label small">Shift</label>
                <select name="EmpShift" class="form-select form-select-sm">
                    <option value="1">1st</option><option value="2">2nd</option><option value="3">3rd</option>
                </select></div>
            <div class="col-4"><label class="form-label small">Rate</label><input name="EmpRate" type="number" step="0.01" class="form-control form-control-sm" value="0"/></div>
            <div class="col-6"><label class="form-label small">Department</label><input name="EmpDept" class="form-control form-control-sm"/></div>
            <div class="col-6"><label class="form-label small">Work Cell</label><input name="EmpWcell" class="form-control form-control-sm"/></div>
            <div class="col-6"><label class="form-label small">Site</label><input name="EmpSite" class="form-control form-control-sm" value="DEFAULT"/></div>
            <div class="col-6"><label class="form-label small">Status</label>
                <select name="EmpStatus" class="form-select form-select-sm">
                    <option value="A">Active</option><option value="T">Terminated</option>
                </select></div>
            <div class="col-12"><label class="form-label small">Notes</label><textarea name="EmpNote" class="form-control form-control-sm" rows="2"></textarea></div>
        </div>
    </div></div>
</div>
<div class="d-flex gap-2 mt-3">
    <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Create Employee</button>
    <a asp-action="Employees" class="btn btn-outline-secondary">Cancel</a>
</div>
</form>
