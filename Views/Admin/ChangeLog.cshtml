@using ZaffreMeld.Web.Models.Administration
@{ ViewData["Title"] = "Audit Log"; }
<div class="page-header"><h4><i class="bi bi-clock-history me-2 text-primary"></i>Audit Log</h4></div>
<div class="card mb-3"><div class="card-body py-2">
<form method="get" class="row g-2 align-items-end">
    <div class="col-sm-3">
        <label class="form-label small mb-1">Table</label>
        <select name="table" class="form-select form-select-sm">
            <option value="">All Tables</option>
            @foreach (string t in (ViewBag.Tables as IEnumerable<string> ?? Array.Empty<string>()))
            { <option value="@t" selected="@(ViewBag.Table==(string)t)">@t</option> }
        </select>
    </div>
    <div class="col-sm-3"><label class="form-label small mb-1">User</label>
        <input name="user" value="@ViewBag.FilterUser" class="form-control form-control-sm" placeholder="Filter by user..."/></div>
    <div class="col-sm-2"><label class="form-label small mb-1">From Date</label>
        <input name="from" type="date" class="form-control form-control-sm"/></div>
    <div class="col-auto"><button class="btn btn-sm btn-outline-primary" type="submit"><i class="bi bi-filter"></i> Filter</button></div>
</form>
</div></div>
<div class="browse-table-wrapper"><table class="table table-sm table-hover mb-0">
    <thead><tr><th>Timestamp</th><th>User</th><th>Table</th><th>Key</th><th>Action</th><th>Field</th><th>Old Value</th><th>New Value</th><th>IP</th></tr></thead>
    <tbody>
    @foreach (ChangeLog log in (ViewBag.Logs as IEnumerable<ChangeLog> ?? Array.Empty<ChangeLog>()))
    {
        <tr>
            <td class="text-nowrap small">@log.ClTimestamp.ToString("yyyy-MM-dd HH:mm:ss")</td>
            <td>@log.ClUser</td>
            <td><span class="badge bg-light text-dark border small">@log.ClTable</span></td>
            <td class="small">@log.ClKey</td>
            <td><span class="badge @(log.ClAction=="INSERT"?"badge-active":log.ClAction=="DELETE"?"badge-inactive":"badge-hold") small">@log.ClAction</span></td>
            <td class="small">@log.ClField</td>
            <td class="small text-muted">@log.ClOldValue</td>
            <td class="small">@log.ClNewValue</td>
            <td class="small text-muted">@log.ClIp</td>
        </tr>
    }
    @if (!(ViewBag.Logs as IEnumerable<ChangeLog> ?? Array.Empty<ChangeLog>()).Any())
    { <tr><td colspan="9" class="text-center text-muted py-4">No audit entries found</td></tr> }
    </tbody>
</table></div>
