@using ZaffreMeld.Web.Models.Administration
@{ ViewData["Title"] = "Sites"; }
<div class="page-header"><h4><i class="bi bi-buildings me-2 text-primary"></i>Sites</h4></div>
<div class="browse-table-wrapper"><table class="table table-sm table-hover mb-0">
    <thead><tr><th>Site</th><th>Description</th><th>Address</th><th>City</th><th>State</th><th>Phone</th></tr></thead>
    <tbody>
    @foreach (SiteMstr s in (ViewBag.Sites as IEnumerable<SiteMstr> ?? Array.Empty<SiteMstr>()))
    {
        <tr>
            <td class="fw-semibold">@s.SiteSite</td>
            <td>@s.SiteDesc</td>
            <td>@s.SiteLine1</td>
            <td>@s.SiteCity</td>
            <td>@s.SiteState</td>
            <td>@s.SitePhone</td>
        </tr>
    }
    @if (!(ViewBag.Sites as IEnumerable<SiteMstr> ?? Array.Empty<SiteMstr>()).Any())
    { <tr><td colspan="6" class="text-center text-muted py-4">No sites configured</td></tr> }
    </tbody>
</table></div>
