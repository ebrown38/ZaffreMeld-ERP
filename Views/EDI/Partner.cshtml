@using ZaffreMeld.Web.Models.EDI
@model EdpPartner
@{ ViewData["Title"] = $"Partner {Model.EdpId}"; }
<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <a asp-action="Partners" class="btn btn-sm btn-outline-secondary me-2"><i class="bi bi-arrow-left"></i></a>
        <h4 class="d-inline"><i class="bi bi-person-badge me-2 text-primary"></i>@Model.EdpDesc</h4>
        <span class="text-muted small ms-1">(@Model.EdpId)</span>
        <span class="badge ms-2 @(Model.EdpActive?"badge-active":"badge-inactive")">@(Model.EdpActive?"Active":"Inactive")</span>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Index" asp-route-partner="@Model.EdpId" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-clock-history me-1"></i>History
        </a>
        <button class="btn btn-sm btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#editModal">
            <i class="bi bi-pencil me-1"></i>Edit
        </button>
    </div>
</div>

<div class="row g-3 mb-3">
    <div class="col-md-5"><div class="form-section">
        <div class="form-section-title">Partner Details</div>
        <div class="row g-2">
            <div class="col-6"><span class="detail-label">Partner ID</span><div class="detail-value">@Model.EdpId</div></div>
            <div class="col-6"><span class="detail-label">Type</span><div>@Model.EdpType</div></div>
            <div class="col-6"><span class="detail-label">ISA Qualifier</span><div><code>@Model.EdpIsa</code></div></div>
            <div class="col-6"><span class="detail-label">GS ID</span><div><code>@Model.EdpGs</code></div></div>
            <div class="col-6"><span class="detail-label">Site</span><div>@Model.EdpSite</div></div>
            <div class="col-6"><span class="detail-label">FTP Profile</span><div>@Model.EdpFtpid</div></div>
            <div class="col-6"><span class="detail-label">AS2 ID</span><div>@Model.EdpAs2id</div></div>
            @if (!string.IsNullOrEmpty(Model.EdpNote))
            { <div class="col-12"><span class="detail-label">Notes</span><div class="small">@Model.EdpNote</div></div> }
        </div>
    </div></div>
    <div class="col-md-7">
        <div class="browse-table-wrapper">
            <div class="px-3 py-2 bg-light border-bottom d-flex justify-content-between align-items-center">
                <span class="fw-semibold small text-muted">CROSS-REFERENCES (GS ID → Customer/Vendor code)</span>
                <button class="btn btn-xs btn-outline-primary" data-bs-toggle="modal" data-bs-target="#xrefModal">
                    <i class="bi bi-plus"></i> Add
                </button>
            </div>
            <table class="table table-sm table-hover mb-0">
                <thead><tr><th>Type</th><th>TP GS ID</th><th>BS Code</th><th>Active</th><th></th></tr></thead>
                <tbody>
                @foreach (EdiXref x in (ViewBag.Xrefs as IEnumerable<EdiXref> ?? Array.Empty<EdiXref>()))
                {
                    <tr>
                        <td><span class="badge bg-light text-dark border small">@x.ExrType</span></td>
                        <td><code class="small">@x.ExrTpaddr</code></td>
                        <td class="fw-semibold">@x.ExrBsaddr</td>
                        <td><span class="badge @(x.ExrActive?"badge-active":"badge-inactive") small">@(x.ExrActive?"Yes":"No")</span></td>
                        <td>
                            <form method="post" asp-action="DeleteXref" asp-route-id="@x.Id" class="d-inline"
                                  onsubmit="return confirm('Delete this xref?')">
                                <input type="hidden" name="returnPartner" value="@Model.EdpId"/>
                                <button class="btn btn-xs btn-outline-danger"><i class="bi bi-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                }
                @if (!(ViewBag.Xrefs as IEnumerable<EdiXref> ?? Array.Empty<EdiXref>()).Any())
                { <tr><td colspan="5" class="text-center text-muted py-3">No xrefs configured</td></tr> }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="browse-table-wrapper">
    <div class="px-3 py-2 bg-light border-bottom"><span class="fw-semibold small text-muted">RECENT TRANSACTIONS</span></div>
    <table class="table table-sm table-hover mb-0">
        <thead><tr><th>Timestamp</th><th>ID</th><th>Doc</th><th>Dir</th><th>Status</th><th></th></tr></thead>
        <tbody>
        @foreach (EdiMstr tx in (ViewBag.History as IEnumerable<EdiMstr> ?? Array.Empty<EdiMstr>()))
        {
            <tr>
                <td class="small">@tx.EdiTimestamp.ToString("yyyy-MM-dd HH:mm")</td>
                <td class="small">@tx.EdiId</td>
                <td><span class="badge bg-light text-dark border small">@tx.EdiDoc2</span></td>
                <td><span class="badge @(tx.EdiDir=="IN"?"badge-open":"badge-closed") small">@tx.EdiDir</span></td>
                <td><span class="badge @(tx.EdiStatus=="A"?"badge-active":"badge-inactive") small">@tx.EdiStatus</span></td>
                <td><a asp-action="Transaction" asp-route-id="@tx.Id" class="btn btn-xs btn-outline-secondary">View</a></td>
            </tr>
        }
        @if (!(ViewBag.History as IEnumerable<EdiMstr> ?? Array.Empty<EdiMstr>()).Any())
        { <tr><td colspan="6" class="text-center text-muted py-3">No transactions</td></tr> }
        </tbody>
    </table>
</div>

<!-- Edit Partner Modal -->
<div class="modal fade" id="editModal" tabindex="-1"><div class="modal-dialog"><div class="modal-content">
    <div class="modal-header"><h5 class="modal-title">Edit Partner</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
    <form method="post" asp-action="EditPartner" asp-route-id="@Model.EdpId">
    <div class="modal-body"><div class="row g-2">
        <div class="col-12"><label class="form-label small">Description</label><input name="EdpDesc" class="form-control form-control-sm" value="@Model.EdpDesc"/></div>
        <div class="col-6"><label class="form-label small">ISA ID</label><input name="EdpIsa" class="form-control form-control-sm" value="@Model.EdpIsa"/></div>
        <div class="col-6"><label class="form-label small">GS ID</label><input name="EdpGs" class="form-control form-control-sm" value="@Model.EdpGs"/></div>
        <div class="col-4"><label class="form-label small">Type</label>
            <select name="EdpType" class="form-select form-select-sm">
                <option value="customer" selected="@(Model.EdpType=="customer")">Customer</option>
                <option value="vendor" selected="@(Model.EdpType=="vendor")">Vendor</option>
                <option value="3pl" selected="@(Model.EdpType=="3pl")">3PL</option>
            </select></div>
        <div class="col-4"><label class="form-label small">Site</label><input name="EdpSite" class="form-control form-control-sm" value="@Model.EdpSite"/></div>
        <div class="col-4"><label class="form-label small">Active</label>
            <select name="EdpActive" class="form-select form-select-sm">
                <option value="true" selected="@Model.EdpActive">Yes</option>
                <option value="false" selected="@(!Model.EdpActive)">No</option>
            </select></div>
        <div class="col-6"><label class="form-label small">FTP Profile</label><input name="EdpFtpid" class="form-control form-control-sm" value="@Model.EdpFtpid"/></div>
        <div class="col-6"><label class="form-label small">AS2 ID</label><input name="EdpAs2id" class="form-control form-control-sm" value="@Model.EdpAs2id"/></div>
        <div class="col-12"><label class="form-label small">Notes</label><textarea name="EdpNote" class="form-control form-control-sm" rows="2">@Model.EdpNote</textarea></div>
    </div></div>
    <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="btn btn-primary btn-sm">Save</button>
    </div>
    </form>
</div></div></div>

<!-- Add Xref Modal -->
<div class="modal fade" id="xrefModal" tabindex="-1"><div class="modal-dialog"><div class="modal-content">
    <div class="modal-header"><h5 class="modal-title">Add Cross-Reference</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
    <form method="post" asp-action="SaveXref">
        <input type="hidden" name="returnPartner" value="@Model.EdpId"/>
    <div class="modal-body"><div class="row g-2">
        <div class="col-12 small text-muted">Maps a trading-partner GS ID (their identifier in the EDI envelope)
            to a ZaffreMeld customer/vendor code for automatic document creation.</div>
        <div class="col-4"><label class="form-label small">Type</label>
            <select name="ExrType" class="form-select form-select-sm">
                <option value="customer">Customer</option>
                <option value="vendor">Vendor</option>
                <option value="shipto">Ship-To</option>
            </select></div>
        <div class="col-4"><label class="form-label small">TP GS ID *</label>
            <input name="ExrTpaddr" class="form-control form-control-sm" placeholder="ACMEPARTNER" required/></div>
        <div class="col-4"><label class="form-label small">BS Code *</label>
            <input name="ExrBsaddr" class="form-control form-control-sm" placeholder="ACME" required/></div>
        <div class="col-4"><label class="form-label small">GS Qualifier</label>
            <input name="ExrBsgs" class="form-control form-control-sm" placeholder="ZZ"/></div>
        <div class="col-4"><label class="form-label small">Active</label>
            <select name="ExrActive" class="form-select form-select-sm">
                <option value="true">Yes</option><option value="false">No</option>
            </select></div>
    </div></div>
    <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="btn btn-primary btn-sm">Save Xref</button>
    </div>
    </form>
</div></div></div>
