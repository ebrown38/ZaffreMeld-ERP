@using ZaffreMeld.Web.Models.EDI
@{ ViewData["Title"] = "EDI Trading Partners"; }
<div class="page-header d-flex justify-content-between align-items-center">
    <h4><i class="bi bi-people me-2 text-primary"></i>EDI Trading Partners</h4>
    <a asp-action="NewPartner" class="btn btn-sm btn-primary"><i class="bi bi-plus-lg me-1"></i>New Partner</a>
</div>
<div class="browse-table-wrapper">
<table class="table table-sm table-hover mb-0">
    <thead><tr><th>ID</th><th>Description</th><th>Type</th><th>ISA ID</th><th>GS ID</th><th>Site</th><th>Active</th><th></th></tr></thead>
    <tbody>
    @foreach (EdpPartner p in (ViewBag.Partners as IEnumerable<EdpPartner> ?? Array.Empty<EdpPartner>()))
    {
        <tr>
            <td><a asp-action="Partner" asp-route-id="@p.EdpId" class="fw-semibold">@p.EdpId</a></td>
            <td>@p.EdpDesc</td>
            <td><span class="badge bg-light text-dark border small">@p.EdpType</span></td>
            <td><code class="small">@p.EdpIsa</code></td>
            <td><code class="small">@p.EdpGs</code></td>
            <td>@p.EdpSite</td>
            <td><span class="badge @(p.EdpActive?"badge-active":"badge-inactive")">@(p.EdpActive?"Active":"Inactive")</span></td>
            <td><a asp-action="Partner" asp-route-id="@p.EdpId" class="btn btn-xs btn-outline-secondary">View</a></td>
        </tr>
    }
    @if (!(ViewBag.Partners as IEnumerable<EdpPartner> ?? Array.Empty<EdpPartner>()).Any())
    { <tr><td colspan="8" class="text-center text-muted py-4">No trading partners configured</td></tr> }
    </tbody>
</table>
</div>
