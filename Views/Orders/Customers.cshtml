@using ZaffreMeld.Web.Models.Orders
@{ ViewData["Title"] = "Customers"; }
<div class="page-header d-flex justify-content-between align-items-center">
    <h4><i class="bi bi-people me-2 text-primary"></i>Customers</h4>
    <a asp-action="NewCustomer" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg me-1"></i>New Customer</a>
</div>
<div class="card mb-3"><div class="card-body py-2">
    <form method="get" class="row g-2 align-items-end">
        <div class="col-sm-4"><input name="q" value="@ViewBag.Q" class="form-control form-control-sm" placeholder="Search code or name…"/></div>
        <div class="col-sm-3"><select name="status" class="form-select form-select-sm">
            <option value="">All Statuses</option>
            <option value="A" selected="@(ViewBag.Status=="A")">Active</option>
            <option value="I" selected="@(ViewBag.Status=="I")">Inactive</option>
        </select></div>
        <div class="col-auto">
            <button class="btn btn-sm btn-outline-primary" type="submit"><i class="bi bi-search"></i></button>
            <a asp-action="Customers" class="btn btn-sm btn-outline-secondary ms-1">Clear</a>
        </div>
    </form>
</div></div>
<div class="browse-table-wrapper"><table class="table table-sm table-hover mb-0">
    <thead><tr><th>Code</th><th>Name</th><th>City</th><th>State</th><th>Phone</th><th>Terms</th><th>Status</th><th></th></tr></thead>
    <tbody>
    @foreach (CmMstr c in (ViewBag.Customers as IEnumerable<CmMstr> ?? Array.Empty<CmMstr>()))
    {
        <tr>
            <td><a asp-action="Customer" asp-route-id="@c.CmCode" class="fw-semibold">@c.CmCode</a></td>
            <td>@c.CmName</td><td>@c.CmCity</td><td>@c.CmState</td><td>@c.CmPhone</td><td>@c.CmTerms</td>
            <td><span class="badge @(c.CmStatus=="A"?"badge-active":"badge-inactive")">@(c.CmStatus=="A"?"Active":"Inactive")</span></td>
            <td><a asp-action="Customer" asp-route-id="@c.CmCode" class="btn btn-xs btn-outline-secondary">View</a></td>
        </tr>
    }
    @if (!(ViewBag.Customers as IEnumerable<CmMstr> ?? Array.Empty<CmMstr>()).Any())
    { <tr><td colspan="8" class="text-center text-muted py-4">No customers found</td></tr> }
    </tbody>
</table></div>
