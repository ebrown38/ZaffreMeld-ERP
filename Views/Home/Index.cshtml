@{ ViewData["Title"] = "Dashboard"; }
<div class="page-header d-flex justify-content-between align-items-center">
    <h4><i class="bi bi-speedometer2 me-2 text-primary"></i>Dashboard</h4>
    <span class="text-muted small">@ViewBag.Site &nbsp;|&nbsp; v@ViewBag.Version</span>
</div>

<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
        <a asp-controller="Orders" asp-action="SalesOrders" asp-route-status="O" class="text-decoration-none">
        <div class="card stat-card orders h-100">
            <div class="card-body d-flex align-items-center">
                <div class="flex-grow-1">
                    <div class="text-muted small text-uppercase">Open Orders</div>
                    <div class="fs-2 fw-bold text-primary">@ViewBag.OpenOrders</div>
                </div>
                <i class="bi bi-cart3 fs-1 text-primary opacity-25"></i>
            </div>
        </div></a>
    </div>
    <div class="col-sm-6 col-xl-3">
        <a asp-controller="Purchasing" asp-action="PurchaseOrders" asp-route-status="O" class="text-decoration-none">
        <div class="card stat-card pos h-100">
            <div class="card-body d-flex align-items-center">
                <div class="flex-grow-1">
                    <div class="text-muted small text-uppercase">Open POs</div>
                    <div class="fs-2 fw-bold text-success">@ViewBag.OpenPos</div>
                </div>
                <i class="bi bi-bag fs-1 text-success opacity-25"></i>
            </div>
        </div></a>
    </div>
    <div class="col-sm-6 col-xl-3">
        <a asp-controller="Shipping" asp-action="Shippers" asp-route-status="O" class="text-decoration-none">
        <div class="card stat-card shippers h-100">
            <div class="card-body d-flex align-items-center">
                <div class="flex-grow-1">
                    <div class="text-muted small text-uppercase">Open Shippers</div>
                    <div class="fs-2 fw-bold" style="color:#f97316">@ViewBag.OpenShippers</div>
                </div>
                <i class="bi bi-truck fs-1 opacity-25" style="color:#f97316"></i>
            </div>
        </div></a>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card workorders h-100">
            <div class="card-body d-flex align-items-center">
                <div class="flex-grow-1">
                    <div class="text-muted small text-uppercase">Work Orders</div>
                    <div class="fs-2 fw-bold" style="color:#a855f7">@ViewBag.OpenWorkOrders</div>
                </div>
                <i class="bi bi-gear fs-1 opacity-25" style="color:#a855f7"></i>
            </div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-header bg-transparent border-bottom py-2">
                <span class="fw-semibold small text-muted text-uppercase"><i class="bi bi-cart3 me-1"></i>Sales</span>
            </div>
            <div class="list-group list-group-flush">
                <a asp-controller="Orders" asp-action="SalesOrders" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center py-2">
                    Sales Orders <i class="bi bi-chevron-right text-muted small"></i>
                </a>
                <a asp-controller="Orders" asp-action="Customers" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center py-2">
                    Customers <i class="bi bi-chevron-right text-muted small"></i>
                </a>
                <a asp-controller="Shipping" asp-action="Shippers" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center py-2">
                    Shipping <i class="bi bi-chevron-right text-muted small"></i>
                </a>
                <a asp-controller="Finance" asp-action="AR" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center py-2">
                    Invoices (AR) <i class="bi bi-chevron-right text-muted small"></i>
                </a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-header bg-transparent border-bottom py-2">
                <span class="fw-semibold small text-muted text-uppercase"><i class="bi bi-bag me-1"></i>Purchasing</span>
            </div>
            <div class="list-group list-group-flush">
                <a asp-controller="Purchasing" asp-action="PurchaseOrders" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center py-2">
                    Purchase Orders <i class="bi bi-chevron-right text-muted small"></i>
                </a>
                <a asp-controller="Purchasing" asp-action="Vendors" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center py-2">
                    Vendors <i class="bi bi-chevron-right text-muted small"></i>
                </a>
                <a asp-controller="Receiving" asp-action="Index" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center py-2">
                    Receiving <i class="bi bi-chevron-right text-muted small"></i>
                </a>
                <a asp-controller="Finance" asp-action="AP" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center py-2">
                    Vouchers (AP) <i class="bi bi-chevron-right text-muted small"></i>
                </a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-header bg-transparent border-bottom py-2">
                <span class="fw-semibold small text-muted text-uppercase"><i class="bi bi-box-seam me-1"></i>Inventory & Finance</span>
            </div>
            <div class="list-group list-group-flush">
                <a asp-controller="Inventory" asp-action="Items" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center py-2">
                    Items <i class="bi bi-chevron-right text-muted small"></i>
                </a>
                <a asp-controller="Inventory" asp-action="Bom" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center py-2">
                    Bill of Materials <i class="bi bi-chevron-right text-muted small"></i>
                </a>
                <a asp-controller="Finance" asp-action="Accounts" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center py-2">
                    Chart of Accounts <i class="bi bi-chevron-right text-muted small"></i>
                </a>
                <a asp-controller="Finance" asp-action="TrialBalance" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center py-2">
                    Trial Balance <i class="bi bi-chevron-right text-muted small"></i>
                </a>
            </div>
        </div>
    </div>
</div>
