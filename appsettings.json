{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "AllowedHosts": "*",

  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=zmdb;User Id=bsuser;Password=bspass;",
    "SqliteConnection": "Data Source=zmdb.db"
  },

  "ZaffreMeld": {
    "DatabaseType": "sqlite",
    "SiteName": "DEFAULT",
    "Version": "7.0",
    "DistDir": "dist/",
    "SourceDir": "src/",
    "RemoteDB": false,
    "DefaultDecimalPlaces": 2,
    "DefaultCurrency": "USD",
    "DefaultLocale": "en-US"
  },

  "Jwt": {
    "Key": "REPLACE-WITH-STRONG-SECRET-KEY-MIN-32-CHARS",
    "Issuer": "ZaffreMeld",
    "Audience": "ZaffreMeld",
    "ExpiryHours": 8
  },

  "Edi": {
    "OurIsaId": "ZAFFREMELD       ",
    "OurGsId":  "ZAFFREMELD",
    "InboundDir": "edi/in",
    "OutboundDir": "edi/out"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/zaffremeld-.log",
          "rollingInterval": "Day"
        }
      }
    ]
  },

  "Smtp": {
    "Host": "smtp.example.com",
    "Port": 587,
    "Username": "",
    "Password": "",
    "FromAddress": "noreply@zaffremeld.com",
    "EnableSsl": true
  }
}
